# Copy to .env.local (gitignored) and fill in. Vite injects VITE_* at build time.
# WARNING: VITE_* values are embedded in the JS bundle and are recoverable by
# inspection. Use a SHARED, PUBLISH-ONLY ingest account constrained by an EMQX
# ACL (publish only to meshcore/client/${clientid}/packets), NOT a real secret.
# Robust identity (companion-signed challenge) is a later hardening.

# Browser PWA runs over HTTPS, so this must be wss:// with a VALID TLS cert
# (a default self-signed EMQX cert will be rejected by the browser).
VITE_MQTT_URL=wss://your-broker.example.com:8084/mqtt
VITE_MQTT_USERNAME=corescope-rx-ingest
VITE_MQTT_PASSWORD=change-me
